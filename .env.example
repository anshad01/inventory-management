# Copy to .env and fill in. Local dev uses a local Postgres; production uses
# a managed Postgres (e.g. Supabase) — only this URL changes.
DATABASE_URL="postgresql://USER:PASSWORD@HOST:5432/DBNAME?schema=public"

# Auth.js (added in a later milestone)
# AUTH_SECRET="generate with: openssl rand -base64 32"
# AUTH_URL="http://localhost:3000"

# Public base URL used to build shareable snapshot links (/s/:token)
# NEXT_PUBLIC_APP_URL="http://localhost:3000"
